# ========================================
# CONFIGURACIÓN - API Generador de TC
# ========================================
# Copia este archivo como .env y completa con tus valores

# Puerto del servidor
PORT=3000

# Ambiente
NODE_ENV=development

# ========================================
# AUTENTICACIÓN BÁSICA (API)
# ========================================
# Requerida en producción para crear/congelar/cancelar/revelar tarjetas
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change_me

# Proveedor de API (stripe, adyen, marqeta)
PROVIDER=stripe

# ========================================
# STRIPE CONFIGURATION (Sandbox)
# ========================================
#
# Obtener claves en: https://dashboard.stripe.com/apikeys
# Importante: Usar claves de PRUEBA (comienzan con pk_test_ y sk_test_)
#

# Clave API privada de Stripe (NUNCA compartir públicamente)
STRIPE_API_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Clave publicable de Stripe (puede ser pública)
STRIPE_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY_HERE

# ========================================
# BASE DE DATOS
# ========================================
# Ruta de la base de datos SQLite local
DB_PATH=./data/cards.db

# ========================================
# LOGS
# ========================================
# Nivel de logging: debug, info, warn, error
LOG_LEVEL=info
